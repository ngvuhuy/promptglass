{
  "name": "@ngvuhuy/promptglass",
  "version": "0.0.0-development",
  "publishConfig": {
    "access": "public"
  },
  "description": "LLM Request Inspector & Benchmarking Tool",
  "bin": {
    "promptglass": "cli.js"
  },
  "files": [
    "cli.js",
    "server/dist",
    "client/dist",
    "shared",
    "package.json"
  ],
  "scripts": {
    "dev": "concurrently --names \"server,client\" --prefix-colors \"yellow,cyan\" \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client && npm run build --prefix server",
    "start": "NODE_ENV=production node server/dist/server/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "eventsource-parser": "^3.0.6",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
